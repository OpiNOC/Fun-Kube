vrrp_instance VI_1 {
    state {{ 'MASTER' if ansible_play_hosts.index(inventory_hostname) == 0 else 'BACKUP' }}
    interface {{ keepalived_interface }}
    virtual_router_id 51
    priority {{ 100 if ansible_play_hosts.index(inventory_hostname) == 0 else 50 }}
    advert_int 1
    authentication {
        auth_type PASS
        auth_pass fun-kube
    }
    virtual_ipaddress {
        {{ keepalived_vip }}
    }
}
