# =============================================================================
# Fun-Kube — Cluster Configuration
# =============================================================================
# Copia questo file in .env e modifica i valori per il tuo ambiente.
#
#   cp .env.example .env
#
# Il file .env NON viene committato su git.
#
# TOPOLOGIE (rilevate automaticamente):
#
#   Local-node        LOCAL_NODE=true, 1 CP, 0 worker
#                     La bootstrap machine È il nodo (tutto in locale)
#
#   Mononodo          1 CP, 0 worker
#                     1 VM remota, fa tutto da sola
#
#   Single CP         1 CP + N worker
#                     1 control-plane + nodi worker separati
#
#   HA multi-CP       3+ CP + N worker + keepalived VIP
#                     Cluster ad alta disponibilità
#
# Nota: se non definisci worker, i nodi CP vengono detaintati automaticamente
# e schedulano anche i workload applicativi.
# =============================================================================


# -----------------------------------------------------------------------------
# CLUSTER
# -----------------------------------------------------------------------------
CLUSTER_NAME=mycluster


# -----------------------------------------------------------------------------
# MODALITÀ LOCAL-NODE
# Imposta true se la bootstrap machine coincide con il nodo stesso.
# In questo caso SSH_USER e SSH_KEY_PATH non sono necessari.
# Compatibile solo con topologia mononodo (1 CP, 0 worker).
# -----------------------------------------------------------------------------
LOCAL_NODE=false


# -----------------------------------------------------------------------------
# NODI
# Formato: NODE_<N>_IP / NODE_<N>_ROLE / NODE_<N>_HOSTNAME
# ROLE: control-plane | worker
#
# Aggiungi o rimuovi blocchi NODE_<N> in base alla topologia desiderata.
# I nodi vengono letti in sequenza fino al primo buco (NODE_1, NODE_2, ...).
# -----------------------------------------------------------------------------
NODE_1_IP=10.0.0.1
NODE_1_ROLE=control-plane
NODE_1_HOSTNAME=cp1

# Esempio con worker dedicati:
# NODE_2_IP=10.0.0.2
# NODE_2_ROLE=worker
# NODE_2_HOSTNAME=worker1

# Esempio HA (3 CP + worker):
# NODE_2_IP=10.0.0.2
# NODE_2_ROLE=control-plane
# NODE_2_HOSTNAME=cp2
# NODE_3_IP=10.0.0.3
# NODE_3_ROLE=control-plane
# NODE_3_HOSTNAME=cp3
# NODE_4_IP=10.0.0.4
# NODE_4_ROLE=worker
# NODE_4_HOSTNAME=worker1


# -----------------------------------------------------------------------------
# SSH
# Non necessari se LOCAL_NODE=true.
# La chiave SSH deve essere pre-caricata sui nodi (authorized_keys).
# L'utente SSH deve poter fare sudo senza password.
# -----------------------------------------------------------------------------
SSH_USER=ubuntu
SSH_KEY_PATH=~/.ssh/id_rsa


# -----------------------------------------------------------------------------
# TIMEZONE
# Applicato a tutti i nodi del cluster.
# -----------------------------------------------------------------------------
CLUSTER_TIMEZONE=Europe/Rome


# -----------------------------------------------------------------------------
# KUBERNETES
# K8S_VERSION: 'latest' risolve automaticamente l'ultima versione stabile,
#              oppure specifica la versione es. v1.32.0
# -----------------------------------------------------------------------------
K8S_VERSION=latest
POD_CIDR=172.16.0.0/16
SERVICE_CIDR=10.96.0.0/12


# -----------------------------------------------------------------------------
# CERTIFICATI API SERVER — SANs aggiuntivi (opzionale)
# IP o hostname extra da includere nel certificato TLS dell'API server.
# Utile se vuoi raggiungere il cluster tramite un IP pubblico o un hostname.
# I CP IPs e la VIP keepalived sono inclusi automaticamente.
# Separati da virgola: es. 203.0.113.10,k8s.miodominio.com
# -----------------------------------------------------------------------------
API_SERVER_EXTRA_SANS=


# -----------------------------------------------------------------------------
# KEEPALIVED — VIP per HA (obbligatorio se CP >= 3)
# VIP: un IP libero sulla subnet dei nodi, non assegnato ad alcun nodo.
# INTERFACE: l'interfaccia di rete principale dei nodi CP (es. eth0, ens3).
# -----------------------------------------------------------------------------
KEEPALIVED_ENABLED=false
KEEPALIVED_VIP=10.0.0.100
KEEPALIVED_INTERFACE=eth0


# -----------------------------------------------------------------------------
# CERT-MANAGER
# Versione di cert-manager installata nel cluster core.
# -----------------------------------------------------------------------------
CERT_MANAGER_VERSION=v1.17.2


# -----------------------------------------------------------------------------
# ADDON — MetalLB (load balancer per IP on-premise)
# IP_POOL: range di IP liberi sulla subnet dei nodi.
# Non deve sovrapporsi a POD_CIDR o SERVICE_CIDR.
# -----------------------------------------------------------------------------
METALLB_ENABLED=false
METALLB_IP_POOL=10.0.0.200-10.0.0.220


# -----------------------------------------------------------------------------
# ADDON — Ingress controller
# TYPE: traefik | nginx-proxy-manager
# -----------------------------------------------------------------------------
INGRESS_ENABLED=false
INGRESS_TYPE=traefik


# -----------------------------------------------------------------------------
# ADDON — Longhorn (storage distribuito)
# RWX: abilita StorageClass ReadWriteMany via NFS interno.
# Nota: open-iscsi e /var/lib/longhorn sono preparati automaticamente
# durante il provisioning del cluster core.
# Per dischi dedicati a Longhorn: vedere documentazione.
# -----------------------------------------------------------------------------
LONGHORN_ENABLED=false
LONGHORN_RWX=false


# -----------------------------------------------------------------------------
# OUTPUT E DEBUG
# -----------------------------------------------------------------------------
OUTPUT_DIR=./output
LOG_LEVEL=info              # info | debug
