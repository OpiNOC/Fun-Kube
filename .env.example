# =============================================================================
# Fun-Kube — Cluster Configuration
# =============================================================================
# Copia questo file in .env e modifica i valori per il tuo ambiente.
# Il file .env NON viene committato su git (.gitignore).
#
# Topologie supportate (rilevate automaticamente dal numero di control-plane):
#   Mononodo:          1 nodo con role=control-plane, nessun worker
#   Single CP:         1 control-plane + N worker
#   HA multi-CP:       3+ control-plane + keepalived VIP + N worker
# =============================================================================


# -----------------------------------------------------------------------------
# CLUSTER
# -----------------------------------------------------------------------------
CLUSTER_NAME=mycluster


# -----------------------------------------------------------------------------
# NODI
# Formato per ogni nodo: NODE_<N>_IP, NODE_<N>_ROLE, NODE_<N>_HOSTNAME
# ROLE: control-plane | worker
# Aggiungi o rimuovi blocchi NODE_<N> in base alla topologia desiderata.
# -----------------------------------------------------------------------------
NODE_1_IP=10.0.0.1
NODE_1_ROLE=control-plane
NODE_1_HOSTNAME=cp1

NODE_2_IP=10.0.0.2
NODE_2_ROLE=control-plane
NODE_2_HOSTNAME=cp2

NODE_3_IP=10.0.0.3
NODE_3_ROLE=control-plane
NODE_3_HOSTNAME=cp3

NODE_4_IP=10.0.0.4
NODE_4_ROLE=worker
NODE_4_HOSTNAME=worker1

NODE_5_IP=10.0.0.5
NODE_5_ROLE=worker
NODE_5_HOSTNAME=worker2


# -----------------------------------------------------------------------------
# SSH
# -----------------------------------------------------------------------------
SSH_USER=ubuntu
SSH_KEY_PATH=~/.ssh/id_rsa


# -----------------------------------------------------------------------------
# KUBERNETES
# -----------------------------------------------------------------------------
K8S_VERSION=latest          # oppure es. 1.30.2
POD_CIDR=172.16.0.0/16
SERVICE_CIDR=10.96.0.0/12


# -----------------------------------------------------------------------------
# RETE — CNI
# -----------------------------------------------------------------------------
CNI=calico


# -----------------------------------------------------------------------------
# KEEPALIVED (HA)
# Obbligatorio solo se control-plane >= 3.
# VIP: IP libero sulla stessa subnet dei nodi (non assegnato ad alcun nodo).
# -----------------------------------------------------------------------------
KEEPALIVED_ENABLED=true
KEEPALIVED_VIP=10.0.0.100
KEEPALIVED_INTERFACE=eth0


# -----------------------------------------------------------------------------
# ADDON — MetalLB
# IP_POOL: range sulla subnet dei nodi, non sovrapposto a POD_CIDR/SERVICE_CIDR
# -----------------------------------------------------------------------------
METALLB_ENABLED=true
METALLB_IP_POOL=10.0.0.200-10.0.0.220


# -----------------------------------------------------------------------------
# ADDON — Ingress
# TYPE: traefik | nginx-proxy-manager
# -----------------------------------------------------------------------------
INGRESS_ENABLED=true
INGRESS_TYPE=traefik


# -----------------------------------------------------------------------------
# ADDON — Longhorn (storage)
# RWX: abilita volumi ReadWriteMany tramite NFS interno
# -----------------------------------------------------------------------------
LONGHORN_ENABLED=true
LONGHORN_RWX=true


# -----------------------------------------------------------------------------
# OUTPUT
# -----------------------------------------------------------------------------
OUTPUT_DIR=./output
LOG_LEVEL=info              # debug | info | warning | error
