# =============================================================================
# Fun-Kube — Cluster Configuration
# =============================================================================
# Copia questo file in .env e modifica i valori per il tuo ambiente.
#
#   cp .env.example .env
#
# Il file .env NON viene committato su git.
#
# TOPOLOGIE (rilevate automaticamente):
#
#   Local-node        LOCAL_NODE=true, 1 CP, 0 worker
#                     La bootstrap machine È il nodo (tutto in locale)
#
#   Mononodo          1 CP, 0 worker
#                     1 VM remota, fa tutto da sola
#
#   Single CP         1 CP + N worker
#                     1 control-plane + nodi worker separati
#
#   HA multi-CP       3+ CP + N worker + keepalived VIP
#                     Cluster ad alta disponibilità
#
# Nota: se non definisci worker, i nodi CP vengono detaintati automaticamente
# e schedulano anche i workload applicativi.
# =============================================================================


# -----------------------------------------------------------------------------
# CLUSTER
# -----------------------------------------------------------------------------
CLUSTER_NAME=mycluster


# -----------------------------------------------------------------------------
# MODALITÀ LOCAL-NODE
# Imposta true se la bootstrap machine coincide con il nodo stesso.
# In questo caso SSH_USER e SSH_KEY_PATH non sono necessari.
# Compatibile solo con topologia mononodo (1 CP, 0 worker).
# -----------------------------------------------------------------------------
LOCAL_NODE=false


# -----------------------------------------------------------------------------
# NODI
# Formato: NODE_<N>_IP / NODE_<N>_ROLE / NODE_<N>_HOSTNAME
# ROLE: control-plane | worker
#
# Aggiungi o rimuovi blocchi NODE_<N> in base alla topologia desiderata.
# I nodi vengono letti in sequenza fino al primo buco (NODE_1, NODE_2, ...).
#
# Topologie:
#   Mononodo:     solo NODE_1 (control-plane)
#   Single CP:    NODE_1 (control-plane) + NODE_4..6 (worker)
#   HA multi-CP:  NODE_1..3 (control-plane) + NODE_4..6 (worker)
# -----------------------------------------------------------------------------
NODE_1_IP=10.0.0.1
NODE_1_ROLE=control-plane
NODE_1_HOSTNAME=cp1

# NODE_2_IP=10.0.0.2
# NODE_2_ROLE=control-plane
# NODE_2_HOSTNAME=cp2

# NODE_3_IP=10.0.0.3
# NODE_3_ROLE=control-plane
# NODE_3_HOSTNAME=cp3

# NODE_4_IP=10.0.0.4
# NODE_4_ROLE=worker
# NODE_4_HOSTNAME=worker1

# NODE_5_IP=10.0.0.5
# NODE_5_ROLE=worker
# NODE_5_HOSTNAME=worker2

# NODE_6_IP=10.0.0.6
# NODE_6_ROLE=worker
# NODE_6_HOSTNAME=worker3


# -----------------------------------------------------------------------------
# SSH
# Non necessari se LOCAL_NODE=true.
# La chiave SSH deve essere pre-caricata sui nodi (authorized_keys).
# L'utente SSH deve poter fare sudo senza password.
# -----------------------------------------------------------------------------
SSH_USER=ubuntu
SSH_KEY_PATH=~/.ssh/id_rsa


# -----------------------------------------------------------------------------
# TIMEZONE
# Applicato a tutti i nodi del cluster.
# -----------------------------------------------------------------------------
CLUSTER_TIMEZONE=Europe/Rome


# -----------------------------------------------------------------------------
# KUBERNETES
# K8S_VERSION: 'latest' risolve automaticamente l'ultima versione stabile,
#              oppure specifica la versione es. v1.32.0
# -----------------------------------------------------------------------------
K8S_VERSION=v1.35.4   # versione testata e funzionante — usa 'latest' per l'ultima stabile
POD_CIDR=172.16.0.0/16
SERVICE_CIDR=10.96.0.0/12


# -----------------------------------------------------------------------------
# CERTIFICATI API SERVER — SANs aggiuntivi (opzionale)
# IP o hostname extra da includere nel certificato TLS dell'API server.
# Utile se vuoi raggiungere il cluster tramite un IP pubblico o un hostname.
# I CP IPs e la VIP keepalived sono inclusi automaticamente.
# Separati da virgola: es. 203.0.113.10,k8s.miodominio.com
# -----------------------------------------------------------------------------
API_SERVER_EXTRA_SANS=


# -----------------------------------------------------------------------------
# KEEPALIVED — VIP per HA (obbligatorio se CP >= 3)
# VIP: un IP libero sulla subnet dei nodi, non assegnato ad alcun nodo.
# INTERFACE: l'interfaccia di rete principale dei nodi CP (es. eth0, ens3).
# -----------------------------------------------------------------------------
KEEPALIVED_ENABLED=false
KEEPALIVED_VIP=10.0.0.100
KEEPALIVED_INTERFACE=eth0


# -----------------------------------------------------------------------------
# CERT-MANAGER
# Versione di cert-manager installata nel cluster core.
# -----------------------------------------------------------------------------
CERT_MANAGER_VERSION=v1.17.2


# -----------------------------------------------------------------------------
# ADDON — MetalLB (load balancer per IP on-premise)
# IP_POOL: range di IP liberi sulla subnet dei nodi.
# Non deve sovrapporsi a POD_CIDR o SERVICE_CIDR.
# -----------------------------------------------------------------------------
METALLB_ENABLED=false
METALLB_IP_POOL=10.0.0.200-10.0.0.220
METALLB_VERSION=v0.15.3     # versione testata — vuoto o 'latest' = ultima da GitHub


# -----------------------------------------------------------------------------
# ADDON — Ingress controller
# TYPE: traefik | nginx-proxy-manager
# SERVICE_TYPE: auto       = LoadBalancer se MetalLB attivo, altrimenti NodePort
#               loadbalancer = richiede MetalLB
#               nodeport     = espone su NodePort (funziona sempre)
# -----------------------------------------------------------------------------
INGRESS_ENABLED=false
INGRESS_TYPE=nginx-proxy-manager
INGRESS_SERVICE_TYPE=auto

# Traefik (usato solo se INGRESS_TYPE=traefik)
# TRAEFIK_LB_IP=            # IP specifico dal pool MetalLB (vuoto = auto-assign)
TRAEFIK_HTTP_NODEPORT=30080
TRAEFIK_HTTPS_NODEPORT=30443
TRAEFIK_IS_DEFAULT_CLASS=true
TRAEFIK_CHART_VERSION=39.0.8  # chart testato (app v3.6.13) — vuoto = ultima versione
# TRAEFIK_DASHBOARD_HOST=   # es. traefik.miodominio.com — vuoto = solo port-forward
# TRAEFIK_ACME_EMAIL=       # es. admin@miodominio.com — vuoto = guida in output/

# Nginx Proxy Manager (usato solo se INGRESS_TYPE=nginx-proxy-manager)
# NPM_LB_IP=                # IP specifico dal pool MetalLB (vuoto = auto-assign)
NPM_HTTP_NODEPORT=30080
NPM_HTTPS_NODEPORT=30443
NPM_ADMIN_NODEPORT=30081
NPM_DB_PASSWORD=T1sh-PwD-Sh0ulD-B3-Ch4nGeD-NOW


# -----------------------------------------------------------------------------
# ADDON — Longhorn (storage distribuito)
#
# Funziona su qualsiasi numero di nodi. Le repliche vengono calcolate
# automaticamente in base ai nodi schedulabili:
#   1 nodo  → 1 replica (nessuna ridondanza)
#   2 nodi  → 2 repliche (ridondanza parziale)
#   3+ nodi → 3 repliche (ridondanza piena, consigliato)
# Fun-Kube avvisa durante 'up' se le repliche sono inferiori a 3.
#
# RWX: abilita StorageClass ReadWriteMany (longhorn-rwx) — necessaria per
#      Nginx Proxy Manager su cluster multi-nodo.
# UI_NODEPORT: espone la dashboard Longhorn su NodePort.
#              Lasciare a 0 per non esporre la UI.
# VERSION: versione di Longhorn da installare.
# Prerequisiti (nfs-common, open-iscsi) installati automaticamente su tutti i nodi.
# -----------------------------------------------------------------------------
LONGHORN_ENABLED=false
LONGHORN_RWX=false
LONGHORN_UI_NODEPORT=31080
LONGHORN_VERSION=v1.11.1    # versione testata — vuoto = default del role


# -----------------------------------------------------------------------------
# ADDON — DN-essence (DNS rewrite manager per CoreDNS)
#
# Gestisce regole di riscrittura DNS in CoreDNS via Custom Resources Kubernetes.
# Utile per risolvere hairpin NAT (domini pubblici che devono risolvere a IP interni).
# Offre UI web, REST API e integrazione kubectl (kubectl get dnsrewrite).
#
# UI_NODEPORT: porta NodePort per accedere alla UI web.
#              Lasciare a 0 per non esporre la UI (accesso solo via port-forward).
# VERSION: versione del Helm chart (vuoto = ultima versione dal registry OCI).
# -----------------------------------------------------------------------------
DN_ESSENCE_ENABLED=true
DN_ESSENCE_UI_NODEPORT=30880   # 0 = UI non esposta (ClusterIP only, usa port-forward)
# DN_ESSENCE_VERSION=          # vuoto = ultima versione


# -----------------------------------------------------------------------------
# Local-path-provisioner (solo mononodo — installato automaticamente)
# Versione del provisioner Rancher usato come StorageClass default su mononodo.
# -----------------------------------------------------------------------------
LOCAL_PATH_VERSION=v0.0.30  # versione testata — vuoto = default del role


# -----------------------------------------------------------------------------
# OUTPUT E DEBUG
# -----------------------------------------------------------------------------
OUTPUT_DIR=./output
LOG_LEVEL=info              # info | debug
