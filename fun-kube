#!/usr/bin/env python3
"""
fun-kube entry point — funziona su Ubuntu 24 pulito senza pip install manuale.
Al primo avvio crea un venv locale e installa le dipendenze automaticamente.
"""
import sys
import os
import subprocess
from pathlib import Path

_HERE = Path(__file__).resolve().parent
_VENV_PYTHON = _HERE / ".venv" / "bin" / "python3"


def _apt_install(pkg: str) -> None:
    print(f"fun-kube: installo pacchetto sistema '{pkg}'...", flush=True)
    subprocess.run(["sudo", "apt-get", "install", "-y", "-q", pkg], check=True)


def _ensure_deps() -> None:
    """Garantisce che typer/rich/python-dotenv siano importabili, poi ri-esegue se necessario."""
    # Se le dipendenze sono già disponibili nell'interprete corrente, nulla da fare
    # (succede quando siamo già dentro il venv)
    try:
        import typer  # noqa: F401
        import rich   # noqa: F401
        return
    except ImportError:
        pass

    venv_dir = _HERE / ".venv"

    # Se il venv esiste già (con il suo Python), ri-esegui direttamente senza reinstallare
    if _VENV_PYTHON.exists():
        os.execv(str(_VENV_PYTHON), [str(_VENV_PYTHON)] + sys.argv)

    # Venv non esiste: crealo da zero
    # Su Ubuntu 24 python3-venv non è preinstallato
    import importlib.util
    if importlib.util.find_spec("ensurepip") is None:
        _apt_install("python3-venv")

    print("fun-kube: primo avvio — preparo ambiente Python...", flush=True)
    subprocess.run([sys.executable, "-m", "venv", str(venv_dir)], check=True)
    subprocess.run(
        [
            str(venv_dir / "bin" / "pip"), "install", "--quiet",
            "typer>=0.12",
            "python-dotenv>=1.0",
            "rich>=13.0",
        ],
        check=True,
    )
    print("fun-kube: dipendenze installate.\n", flush=True)

    # Ri-esegui con il Python del venv
    os.execv(str(_VENV_PYTHON), [str(_VENV_PYTHON)] + sys.argv)


_ensure_deps()

sys.path.insert(0, str(_HERE))

from fun_kube.cli import main  # noqa: E402

if __name__ == "__main__":
    main()
